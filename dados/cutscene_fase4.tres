[gd_resource type="Resource" script_class="CutsceneData" format=3 uid="uid://vc4q5n1rs0gn"]

[ext_resource type="Script" uid="uid://c5glm0xyacp85" path="res://scripts/cutscene/fala.gd" id="1_mvr31"]
[ext_resource type="Script" uid="uid://c7b30pn8iiafg" path="res://scripts/cutscene/cutscene_data.gd" id="2_318re"]

[sub_resource type="Resource" id="Resource_627ml"]
script = ExtResource("1_mvr31")
texto = "O inverno foi difícil, mas consegui superar cada desafio."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_pq4vd"]
script = ExtResource("1_mvr31")
personagem = "garca"
texto = "A multiplicação transforma esforço em crescimento. Cada lição aprendida produziu muitas outras."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_yo2i2"]
script = ExtResource("1_mvr31")
texto = "Agora vejo que a matemática esteve presente em cada passo da minha caminhada."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_8f2ra"]
script = ExtResource("1_mvr31")
personagem = "garca"
texto = "E graças a ela você se tornou muito mais do que imaginava quando começou."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_mvr31"]
script = ExtResource("1_mvr31")
texto = "Quando saí do lago, eu era apenas um jovem cheio de sonhos e dúvidas."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_318re"]
script = ExtResource("1_mvr31")
personagem = "garca"
texto = "Agora você possui conhecimento, experiência e confiança para seguir seu próprio caminho."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_40m76"]
script = ExtResource("1_mvr31")
texto = "Aprendi que a matemática não serve apenas para resolver contas."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

[sub_resource type="Resource" id="Resource_31sal"]
script = ExtResource("1_mvr31")
personagem = "garca"
texto = "A matemática ajuda a entender o mundo. Vá, explorador. Novas aventuras o aguardam."
metadata/_custom_type_script = "uid://c5glm0xyacp85"

